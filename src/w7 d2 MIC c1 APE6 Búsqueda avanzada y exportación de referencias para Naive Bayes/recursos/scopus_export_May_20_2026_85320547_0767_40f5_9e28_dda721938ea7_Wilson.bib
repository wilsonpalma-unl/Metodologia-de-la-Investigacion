@ARTICLE{Elgeldawi2021,
	author = {Elgeldawi, Enas and Sayed, Awny and Galal, Ahmed R. and Zaki, Alaa M.},
	title = {Hyperparameter tuning for machine learning algorithms used for arabic sentiment analysis},

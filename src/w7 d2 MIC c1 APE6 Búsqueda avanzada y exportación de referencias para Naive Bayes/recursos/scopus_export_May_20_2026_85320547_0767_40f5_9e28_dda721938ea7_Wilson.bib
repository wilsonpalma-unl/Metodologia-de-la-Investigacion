@ARTICLE{Ramayanti20251482,
	author = {Ramayanti, Indri and Hermawan, Latius and Syakurah, Rizma Adlia and Stiawan, Deris and Meilinda and Negara, Edi Surya and Fahmi, Muhammad and Ghiffari, Ahmad and Rizqie, Muhammad Qurhanul},
	title = {Sentiment and Emotion Classification Models Using Hybrid Textual and Numerical Features: A Case Study of Mental Health Counseling},
	year = {2025},
	journal = {Journal of Applied Data Sciences},
	volume = {6},

@ARTICLE{Wang202097370,
	author = {Wang, Peng and Yan, Yun and Si, Yingdong and Zhu, Gancheng and Zhan, Xiangping and Wang, Jun and Pan, Runsheng},
	title = {Classification of Proactive Personality: Text Mining Based on Weibo Text and Short-Answer Questions Text},
	year = {2020},

@ARTICLE{Salleh20241651,
	author = {Salleh, Amran and Said, Mar Yah and Osman, Mohd Hafeez and Hassan, Sa’Adah},
	title = {A Review on Classifying and Prioritizing User Review-Based Software Requirements},
	year = {2024},
	journal = {International Journal on Informatics Visualization},

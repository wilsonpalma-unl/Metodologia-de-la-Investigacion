	url = {https://www.scopus.com/pages/publications/105038336206?origin=resultslist},
	abstract = {High-quality asynchronous online discussions play a crucial role in facilitating learners’ knowledge construction and serve as an important indicator of online learning effectiveness. However, existing automatic evaluation approaches primarily rely on behavioral metrics (e.g., number of posts, replies, or text length), attitude questionnaires, or manually annotated discussion data. These methods often yield coarse-grained results and depend heavily on expert annotations. Drawing on the perspective of knowledge construction, this study develops a comprehensive evaluation framework and an intelligent annotation–based model for automatically assessing the quality of asynchronous online discussions. Based on this model, targeted intervention strategies were further designed and empirically validated. The findings indicate that the intelligent annotation method achieves higher accuracy than models trained with manual labeling and enables fine-grained evaluation of learners’ knowledge construction levels. Among the Naive Bayes, SVM, and KNN algorithms, the Naive Bayes–based intelligent annotation demonstrates the best performance for multi-class text classification. Furthermore, the proposed model-driven strategies—addressing cognitive enhancement, affective engagement, and self-regulated learning—effectively improve learners’ performance and discussion quality in online learning environments. © 2025 Copyright held by the owner/author(s).},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access}
}


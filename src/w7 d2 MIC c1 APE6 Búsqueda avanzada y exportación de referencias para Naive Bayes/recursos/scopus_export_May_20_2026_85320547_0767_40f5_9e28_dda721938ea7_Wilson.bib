@ARTICLE{Jasmir20241172,
	author = {Jasmir, Jasmir and Abidin, Dodo Zaenal and Fachruddin, Fachruddin and Riyadi, Willy},
	title = {Experimental of information gain and AdaBoost feature for machine learning classifier in media social data},
	year = {2024},

@ARTICLE{Azrir2024214,
	author = {Azrir, Ahmad Hariz Imran Bin Ahmad and Naveen, Palanichamy and Haw, Su-Cheng},
	title = {Sentiment Analysis using Machine Learning Models on Shopee Reviews},
	year = {2024},
	journal = {Journal of System and Management Sciences},
	volume = {14},

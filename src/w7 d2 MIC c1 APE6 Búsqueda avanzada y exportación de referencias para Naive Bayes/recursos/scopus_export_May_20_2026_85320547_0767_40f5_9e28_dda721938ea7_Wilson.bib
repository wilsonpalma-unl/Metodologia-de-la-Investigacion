@CONFERENCE{Wagh2021732,
	author = {Wagh, Vedangi and Khandve, Snehal and Joshi, Isha and Wani, Apurva and Kale, Geetanjali and Joshi, Raviraj},
	title = {Comparative Study of Long Document Classification},
	year = {2021},

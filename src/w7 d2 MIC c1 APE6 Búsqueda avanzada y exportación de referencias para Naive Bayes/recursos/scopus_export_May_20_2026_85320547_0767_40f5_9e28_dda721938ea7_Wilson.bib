@ARTICLE{Flores202029270,
	author = {Flores, Christopher A. and Figueroa, Rosa L. and Pezoa, Jorge E. and Zeng-Treitler, Qing},
	title = {CREGEX: A Biomedical Text Classifier Based on Automatically Generated Regular Expressions},

@ARTICLE{Mary2023357,
	author = {Mary, T Ananthi Claral and Rose, P. J Arul Leena},
	title = {Multifaceted Sentiment Detection System (MSDS) to Avoid Dropout in Virtual Learning Environment using Multi-class Classifiers},
	year = {2023},
	journal = {International Journal of Advanced Computer Science and Applications},
	volume = {14},

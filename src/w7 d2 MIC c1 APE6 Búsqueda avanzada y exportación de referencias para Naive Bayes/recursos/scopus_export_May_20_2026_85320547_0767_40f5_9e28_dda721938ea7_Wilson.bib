@ARTICLE{Ebad2024,
	author = {Ebad, Shouki A. and Subait, Wala Bin and Nemri, Nadhem and Almukadi, Wafa Sulaiman and Aljohani, Nasser and Yafoz, Ayman and Alsini, Raed and Duhayyim, Mesfer Al},
	title = {INTEGRATING FRACTAL SNOW ABLATION OPTIMIZER with BAYESIAN MACHINE LEARNING for ASPECT-LEVEL SENTIMENT ANALYSIS on SOCIAL MEDIA},
	year = {2024},
	journal = {Fractals},

@ARTICLE{Patil202534,
	author = {Patil, Srishti Sudhir and Suryawanshi, Vaishali Pankaj and Patil, Sudhir Madhav and Girase, Sheetal Pravin and Bhagat, Dhananjay Abhilash},
	title = {Review of sentiment analysis in social media using big data: techniques, tools, and frameworks},
	year = {2025},
	journal = {International Journal of Basic and Applied Sciences},
	volume = {14},

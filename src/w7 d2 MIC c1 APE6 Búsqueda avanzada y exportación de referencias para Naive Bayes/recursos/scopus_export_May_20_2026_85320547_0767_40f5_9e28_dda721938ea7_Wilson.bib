@ARTICLE{Pookduang202520167,
	author = {Pookduang, Pongsathon and Klangbunrueang, Rapeepat and Chansanam, Wirapong and Lunrasri, Tassanee},
	title = {Advancing Sentiment Analysis: Evaluating RoBERTa against Traditional and Deep Learning Models},

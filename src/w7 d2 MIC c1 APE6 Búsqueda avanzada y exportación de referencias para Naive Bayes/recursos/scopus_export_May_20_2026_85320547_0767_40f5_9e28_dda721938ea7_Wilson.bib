	author = {Aljameel, Sumayh S. and Alabbad, Dina A. and Alzahrani, Norah A. and Alqarni, Shouq M. and Alamoudi, Fatimah A. and Babili, Lana M. and Aljaafary, Somiah K. and Alshamrani, Fatima M.},
	title = {A sentiment analysis approach to predict an individual’s awareness of the precautionary procedures to prevent covid-19 outbreaks in Saudi Arabia},

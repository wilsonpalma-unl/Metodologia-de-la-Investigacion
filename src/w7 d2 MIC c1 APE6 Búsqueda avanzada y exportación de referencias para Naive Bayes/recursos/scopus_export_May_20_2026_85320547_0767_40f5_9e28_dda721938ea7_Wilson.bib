@ARTICLE{Gautam202358,
	author = {Gautam, Arvind Kumar and Bansal, Abhishek},
	title = {Automatic Cyberstalking Detection on Twitter in Real-Time using Hybrid Approach},
	year = {2023},
	journal = {International Journal of Modern Education and Computer Science},
	volume = {15},

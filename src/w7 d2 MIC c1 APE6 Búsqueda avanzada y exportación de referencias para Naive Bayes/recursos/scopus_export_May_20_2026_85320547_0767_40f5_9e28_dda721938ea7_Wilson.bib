	title = {Machine Learning Approaches for Multi-Class Emotion Recognition in English Social Media Text: A Comprehensive Comparative Analysis},
	year = {2026},
	journal = {Proceedings of 2025 6th International Conference on Computer Science and Management Technology, ICCSMT 2025},
	pages = {215 - 220},
	doi = {10.1145/3795154.3795188},
	url = {https://www.scopus.com/pages/publications/105036562286?origin=resultslist},
	abstract = {Emotion recognition from social media text has emerged as a critical task in natural language processing with applications spanning mental health monitoring, customer sentiment analysis, and human-computer interaction. This study presents a comprehensive comparative analysis of classical machine learning and deep learning approaches for multi-class emotion classification in English Twitter text. We systematically evaluate six distinct models-Logistic Regression, Random Forest, Naive Bayes, CNN, BiLSTM, and CNN-LSTM hybrid architecture-on a dataset comprising six emotion categories: sadness, joy, love, anger, fear, and surprise. Our preprocessing pipeline integrates lexical normalization, morphological processing, and dual feature representation strategies using TF-IDF for traditional models and sequence embedding for neural architectures. Experimental results demonstrate that CNN achieves the highest performance with 91.45% test accuracy and a mean AUC of 0.992, significantly outperforming traditional approaches. The hybrid CNN-LSTM model, while computationally more complex, achieves only 45.6% accuracy, suggesting that architectural complexity does not guarantee superior performance for this task. Our analysis reveals that joy and sadness are the most reliably classified emotions across all models, while surprise remains challenging due to its semantic similarity with other emotional states. This work provides empirical evidence for the effectiveness of convolutional architectures in capturing local emotional patterns in short social media text. © 2025 Copyright held by the owner/author(s).},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access}
}


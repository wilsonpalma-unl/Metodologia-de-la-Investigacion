@ARTICLE{Balakrishnan2021171,
	author = {Balakrishnan, Vimala and Kaity, Mohammed and Rahim, Hajar Abdul and Ismail, Nazari},
	title = {Social Media Analytics using Sentiment and Content Analyses on The 2018 Malaysia’s General Election},

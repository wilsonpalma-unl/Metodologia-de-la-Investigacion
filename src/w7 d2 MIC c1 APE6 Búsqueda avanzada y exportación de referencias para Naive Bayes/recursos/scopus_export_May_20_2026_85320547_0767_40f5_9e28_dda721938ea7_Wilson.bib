	doi = {10.19101/IJATEE.2021.875886},
	url = {https://www.scopus.com/pages/publications/85149479500?origin=resultslist},
	abstract = {Everyday enormous amount of data is generated from various internet sources like social media sites, e-mails, consumer reviews, etc. In this competitive world, it is mandatory for every organization to understand its consumers to satisfy their requirements. In order to get substantial insights from human languages in the form of reviews and to understand consumer perceptions, sentiment analysis is the best way. Therefore, this research article proposes a text preprocessing approach with three stages: data collection, cleaning, and transformation. All these techniques have been practiced on three datasets (restaurant dataset, cell phone dataset, garments dataset) and evaluated using various machine learning classifiers for sentiments predictions. Furthermore, a comparison has also been done on two sets, in the set1 data cleaning, transformation with stemming is used. In set2 data cleaning, transformation with lemmatization is used. The result of this comparison shows that set2 (data cleaning, transformation with lemmatization) gives better performance for preprocessing while evaluated using various machine learning classifiers such as support vector machine(SVM), logistic regression (LR), decision tree (DT), random forest (RF), Naïve Bayes (NB). Here, SVM, LR, RF, and NB give better performance for the restaurant dataset, in the case of the cell phone dataset DT, LR and RFoutperformed. Further, in the garments dataset LR, DT, and RFoutperformedfor set2 as compared to set1. So, set2 is considered as best for subsequent comparison. Moreover, in another comparison two sets are used, set3 contains text cleaning, transformation with lemmatization, and unigram features. Another set contains text cleaning, transformation with lemmatization, and bigram features and is evaluated using machine learning classifiers. In this comparison, it is revealed that set3 gives the best performance with the majority of classifiers. © 2023 Kartika Makkar et al.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},

@ARTICLE{Mudarakola2025,
	author = {Mudarakola, Lakshmi Prasad and Gatla, Ranjith Kumar and Raju, Akella S. Narasimha and Jaffar, Amar Y. and Alzahrani, Abdullah and Dessalegn, Adis Abebaw},
	title = {Multi stage sentiment analysis for product reviews on Twitter using optimized machine learning algorithm},
	year = {2025},
	journal = {Scientific Reports},

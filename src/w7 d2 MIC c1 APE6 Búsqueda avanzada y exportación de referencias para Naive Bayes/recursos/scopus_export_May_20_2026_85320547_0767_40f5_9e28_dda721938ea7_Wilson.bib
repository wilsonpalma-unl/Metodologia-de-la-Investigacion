@ARTICLE{Lu2025,
	author = {Lu, Liyuan},
	title = {Advanced sentiment analysis in online shopping: Implementing LSTM models analyzing E-commerce user sentiments},
	year = {2025},
	journal = {Nonlinear Engineering},
	volume = {14},
	number = {1},

@ARTICLE{Sharin2025295,
	author = {Sharin, Nur Hafazah Binti and Kartiwi, Mira},
	title = {IDENTIFYING TECHNICAL AND VOCATIONAL EDUCATION AND TRAINING (TVET) SENTIMENT FROM SOCIAL MEDIA USING MACHINE LEARNING APPROACH},
	year = {2025},
	journal = {IIUM Engineering Journal},
	volume = {26},

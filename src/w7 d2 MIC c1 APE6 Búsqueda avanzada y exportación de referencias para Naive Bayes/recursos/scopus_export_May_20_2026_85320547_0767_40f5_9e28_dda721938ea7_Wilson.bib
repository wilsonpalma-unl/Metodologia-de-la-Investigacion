@ARTICLE{Badache2022,
	author = {Badache, Ismail and Chifu, Adrian-Gabriel and Fournier, Sébastien},
	title = {Unsupervised and Supervised Methods to Estimate Temporal-Aware Contradictions in Online Course Reviews},
	year = {2022},

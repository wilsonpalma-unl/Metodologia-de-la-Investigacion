@ARTICLE{Deshpande2025,
	author = {Deshpande, Sudhindra B. and Tangod, Kiran K. and Srinivasaiah, Sowmyashree H. and Alahmadi, Ahmad Aziz and Alwetaishi, Mamdooh and Ong Michael, Goh Kah and Rajendran, Silambarasan},

@ARTICLE{Prasetyo2026141,
	author = {Prasetyo, Heru Adi and Suryani, Vera and Sulistiyo, Mahmud Dwi},
	title = {Towards Enhanced Detection of Website Defacement: A Hybrid Model Combining Transformer NLP and MITRE ATT&CK TTPs},
	year = {2026},
	journal = {International Journal of Intelligent Engineering and Systems},

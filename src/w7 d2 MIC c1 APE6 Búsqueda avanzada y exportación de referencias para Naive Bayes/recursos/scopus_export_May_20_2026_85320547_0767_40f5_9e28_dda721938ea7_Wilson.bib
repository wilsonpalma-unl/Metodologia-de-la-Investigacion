@ARTICLE{Padmalal2024208,
	author = {Padmalal, S. and Edwin Dayanand, I. and Rao, Goda Srinivasa and Gore, Santosh},
	title = {Enhancing Sentiment Analysis in Social Media Texts Using Transformer-Based NLP Models},

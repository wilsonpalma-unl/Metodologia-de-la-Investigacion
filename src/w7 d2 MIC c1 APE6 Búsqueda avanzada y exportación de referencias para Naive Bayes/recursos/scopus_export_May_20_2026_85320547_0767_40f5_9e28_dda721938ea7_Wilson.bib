	source = {Scopus},
	note = {Cited by: 17; All Open Access; Green Open Access}
}

@ARTICLE{Shafi202195456,
	author = {Shafi, Imran and Din, Sadia and Hussain, Zahid and Ashraf, Imran and Choi, Gyu Sang},
	title = {Adaptable Reduced-Complexity Approach Based on State Vector Machine for Identification of Criminal Activists on Social Media},
	year = {2021},
	journal = {IEEE Access},

@ARTICLE{Kahya Özyirmidokuz2025,
	author = {Kahya Özyirmidokuz, Esra and Molu Elmas, Bengisu and Stoica, Eduard Alexandru},
	title = {AI-Based Sentiment Analysis of E-Commerce Customer Feedback: A Bilingual Parallel Study on the Fast Food Industry in Turkish and English},
